{
  "name": "nyx",
  "productName": "NYX",
  "private": true,
  "version": "3.0.0",
  "author": "NYX Dev Team",
  "description": "NYX is a premium, high-fidelity AI coding environment and runner that executes powerful local models on your GPU and orchestrates cloud LLMs, featuring advanced model management, side-by-side comparisons, and zero-delay streaming inside a beautifully crafted interface.",
  "type": "module",
  "main": "dist-electron/main.cjs",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "npm run build:server && electron-vite build",
    "build:server": "esbuild server.ts --bundle --platform=node --target=node22 --format=cjs --outfile=dist-server/server.cjs --packages=external",
    "package": "npm run build && electron-builder --config electron-builder.config.cjs",
    "clean": "node -e \"const fs = require('fs'); if (fs.existsSync('dist')) fs.rmSync('dist', { recursive: true, force: true }); if (fs.existsSync('dist-server')) fs.rmSync('dist-server', { recursive: true, force: true }); if (fs.existsSync('dist-desktop')) fs.rmSync('dist-desktop', { recursive: true, force: true })\"",
    "prepare": "husky",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,md}\""
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/language": "^6.12.3",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.43.0",
    "@fastify/cors": "^11.2.0",
    "@fontsource-variable/geist": "^5.2.8",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@sentry/electron": "^7.13.0",
    "@tailwindcss/vite": "^4.1.14",
    "@tanstack/react-virtual": "^3.13.26",
    "@types/helmet": "^0.0.48",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@types/three": "^0.184.1",
    "@vitejs/plugin-react": "^5.0.4",
    "@xenova/transformers": "^2.0.1",
    "async-mutex": "^0.5.0",
    "better-sqlite3": "^12.9.0",
    "check-disk-space": "^3.4.0",
    "chokidar": "^5.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.45.2",
    "electron-store": "^10.0.0",
    "electron-updater": "^6.6.1",
    "electron-window-state": "^5.0.3",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.2",
    "fastify": "^5.3.2",
    "fuse.js": "^7.3.0",
    "helmet": "^8.2.0",
    "lottie-react": "^2.4.1",
    "lucide-react": "^0.546.0",
    "motion": "^12.40.0",
    "p-queue": "^9.3.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "pino-roll": "^4.0.0",
    "proper-lockfile": "^4.1.2",
    "ps-list": "^8.1.1",
    "pidusage": "^3.0.2",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.1",
    "recharts": "^3.8.1",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.7",
    "systeminformation": "^5.31.6",
    "tailwind-merge": "^3.5.0",
    "three": "^0.184.0",
    "tree-kill": "^1.2.2",
    "tw-animate-css": "^1.4.0",
    "undici": "^8.2.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@vitest/ui": "^4.1.7",
    "autoprefixer": "^10.4.21",
    "drizzle-kit": "^0.18.1",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^3.1.0",
    "electronmon": "^2.0.4",
    "esbuild": "^0.28.0",
    "eslint": "^10.4.0",
    "eslint-plugin-boundaries": "^6.0.2",
    "husky": "^9.1.7",
    "knip": "^6.14.2",
    "lint-staged": "^17.0.5",
    "msw": "^2.14.6",
    "playwright": "^1.60.0",
    "prebuild-install": "^7.1.3",
    "prettier": "^3.8.3",
    "shadcn": "^4.8.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "typescript-eslint": "^8.60.0",
    "vite": "^6.2.3",
    "vitest": "^4.1.7"
  },
  "overrides": {
    "esbuild": "^0.28.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  }
}
