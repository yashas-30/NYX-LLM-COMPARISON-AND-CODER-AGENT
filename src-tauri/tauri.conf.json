{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "NYX",
  "version": "3.0.0",
  "identifier": "com.nyx.app",
  "build": {
    "beforeDevCommand": "npm run dev:web",
    "beforeBuildCommand": "npm run build:web && npm run build:server",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:3000"
  },
  "app": {
    "windows": [
      {
        "title": "NYX - Native Local Intelligence & Cloud Orchestration Platform",
        "width": 1440,
        "height": 900,
        "minWidth": 900,
        "minHeight": 600,
        "center": true,
        "visible": false
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self'",
        "script-src": "'self' 'unsafe-eval' 'unsafe-inline'",
        "style-src": "'self' 'unsafe-inline' https://fonts.googleapis.com",
        "font-src": "'self' https://fonts.gstatic.com",
        "connect-src": "'self' http://127.0.0.1:* ws://127.0.0.1:* https://*.googleapis.com https://*.huggingface.co https://*.openrouter.ai https://*.nvidia.com https://*.opencode.ai https://*.pollinations.ai",
        "img-src": "'self' data: https:",
        "media-src": "'self'"
      },
      "capabilities": ["default"]
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "dmg", "appimage", "deb"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": ["../dist-server", "../dist"],
    "windows": {
      "webviewInstallMode": { "type": "downloadBootstrapper" }
    },
    "macOS": {
      "frameworks": [],
      "minimumSystemVersion": "10.13",
      "signingIdentity": null,
      "entitlements": null
    },
    "linux": { "deb": { "depends": ["nodejs", "python3"] } }
  },
  "plugins": {
    "updater": {
      "active": true,
      "dialog": true,
      "pubkey": "YOUR_ED25519_PUBLIC_KEY_HERE",
      "endpoints": ["https://github.com/yashas-30/NYX/releases/latest/download/latest.json"]
    }
  }
}
